# ============================================
# VARIABLES DE ENTORNO — M&D Hijos del Rey
# ============================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env a GitHub.
# En Vercel: Settings → Environment Variables

# ── SUPABASE ─────────────────────────────────
# Obtén estos valores desde: https://supabase.com/dashboard → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://TU_PROYECTO_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...tu_anon_key_aqui

# ── GROQ (Chatbot IA) ─────────────────────────
# Obtén una nueva key en: https://console.groq.com/keys
# IMPORTANTE: Si la key actual fue expuesta, revócala y genera una nueva.
VITE_GROQ_API_KEY=gsk_...tu_nueva_key_aqui

# ── WOMPI (Pasarela de Pago) ──────────────────
# Obtén tu llave de PRODUCCIÓN en: https://comercios.wompi.co
# → Panel → Configuración → Llaves de API
# Para producción usa: pub_prod_XXXXX (NO pub_test_XXXXX)
# Para pruebas/staging usa: pub_test_XXXXX
VITE_WOMPI_PUBLIC_KEY=pub_prod_...tu_llave_real_aqui
